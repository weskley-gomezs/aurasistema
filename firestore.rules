rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'costPrice', 'sellPrice', 'quantity']) &&
             data.id is string &&
             data.name is string && data.name.size() <= 200 &&
             data.costPrice is number &&
             data.sellPrice is number &&
             data.quantity is number;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['id', 'date', 'customerName', 'items', 'totalAmount', 'status']) &&
             data.id is string &&
             data.date is string &&
             data.customerName is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.status is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && isValidProduct(incoming());
      allow delete: if isValidId(productId);
    }

    match /customers/{customerId} {
      allow read: if true;
      allow create: if isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isValidId(customerId) && isValidCustomer(incoming());
      allow delete: if isValidId(customerId);
    }

    match /sales/{saleId} {
      allow read: if true;
      allow create: if isValidId(saleId) && isValidSale(incoming());
      allow update: if isValidId(saleId) && isValidSale(incoming());
      allow delete: if isValidId(saleId);
    }

    // Migration flag / system docs
    match /system/{docId} {
      allow read, write: if true;
    }
    
    // Connection test doc
    match /test/connection {
      allow get: if true;
    }
  }
}
