{
  "entities": {
    "product": {
      "title": "Product",
      "description": "Product in inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "costPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "photoUrl": { "type": "string" }
      },
      "required": ["id", "name", "costPrice", "sellPrice", "quantity"]
    },
    "customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "sale": {
      "title": "Sale",
      "description": "Sale record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "profitAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "paidDate": { "type": "string" },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "date", "customerName", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "product",
      "description": "Collection of products"
    },
    "customers/{customerId}": {
      "schema": "customer",
      "description": "Collection of customers"
    },
    "sales/{saleId}": {
      "schema": "sale",
      "description": "Collection of sales"
    }
  }
}
